# ---- Required (the app fails loud without these) ----
# Company API key from https://whop.com/dashboard/developer
WHOP_API_KEY=
# The company that owns products/plans (the company your API key belongs to), e.g. biz_XXXXXXXX
WHOP_COMPANY_ID=

# ---- Optional ----
# Parent company used when "Create business" spins up a sub-company. Defaults to WHOP_COMPANY_ID.
WHOP_PARENT_COMPANY_ID=
# App id, only if your embedded components require it.
NEXT_PUBLIC_WHOP_APP_ID=
# Enables AI business-plan generation. Without it, a static template is used.
ANTHROPIC_API_KEY=
# Override the Claude model used for the business plan.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Used to build booking / referral links and checkout return URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
